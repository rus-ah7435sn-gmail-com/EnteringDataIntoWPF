<Window x:Class="MyPrismApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MyPrismApp"
        xmlns:prism="http://prismlibrary.com/"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}" Height="450" Width="800">
    <Grid Margin="10" PreviewMouseLeftButtonDown="Grid_PreviewMouseLeftButtonDown">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Label Content="Input Text 1 Region:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"/>
        <ContentControl prism:RegionManager.RegionName="RegionTextField1" Grid.Row="0" Grid.Column="1" Margin="5"/>

        <Label Content="Input Text 2 Region:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center"/>
        <ContentControl prism:RegionManager.RegionName="RegionTextField2" Grid.Row="1" Grid.Column="1" Margin="5"/>

        <Label Content="Input Text 3 Region:" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center"/>
        <ContentControl prism:RegionManager.RegionName="RegionTextField3" Grid.Row="2" Grid.Column="1" Margin="5"/>

        <Label Content="Disabled Text Region:" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center"/>
        <ContentControl prism:RegionManager.RegionName="RegionDisabledTextField" Grid.Row="3" Grid.Column="1" Margin="5"/>

        <Label Content="Поле ввода Region:" Grid.Row="4" Grid.Column="0" VerticalAlignment="Center"/>
        <ContentControl prism:RegionManager.RegionName="RegionInputField" Grid.Row="4" Grid.Column="1" Margin="5"/>

        <!-- Опционально: можно раскомментировать, если ContentRegion из первоначальной настройки все еще нужен -->
        <!-- <Label Content="Original Content Region:" Grid.Row="4" Grid.Column="0" VerticalAlignment="Center"/> -->
        <!-- <ContentControl prism:RegionManager.RegionName="ContentRegion" Grid.Row="4" Grid.Column="1" Margin="5"/> -->
    </Grid>
</Window>
